generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id             String          @id @default(cuid())
  name           String
  avatar         String          @default("🧬")
  pin            String?
  xp             Int             @default(0)
  level          Int             @default(1)
  streakCount    Int             @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  attempts       Attempt[]
  skillMasteries SkillMastery[]
  profileBadges  ProfileBadge[]
  lessonProgress LessonProgress[]
}

model Subject {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  icon        String
  color       String
  order       Int
  topics      Topic[]
}

model Topic {
  id               String         @id @default(cuid())
  subjectId        String
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  slug             String
  yearBand         String
  title            String
  description      String
  surgeonRelevance String
  order            Int
  lessons          Lesson[]
  questions        Question[]
  skillMasteries   SkillMastery[]

  @@unique([subjectId, slug])
}

model Lesson {
  id              String           @id @default(cuid())
  topicId         String
  topic           Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  slug            String
  title           String
  content         String
  medicalCallout  String?
  interactiveRef  String?
  order           Int
  xpReward        Int              @default(25)
  lessonProgress  LessonProgress[]

  @@unique([topicId, slug])
}

model Question {
  id          String    @id @default(cuid())
  topicId     String
  topic       Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  type        String
  prompt      String
  options     String?
  answer      String
  explanation String
  difficulty  Int       @default(1)
  interactiveConfig String?
  attempts    Attempt[]
}

model Attempt {
  id             String   @id @default(cuid())
  profileId      String
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  correct        Boolean
  response       String?
  responseTimeMs Int?
  createdAt      DateTime @default(now())

  @@index([profileId, createdAt])
}

model SkillMastery {
  id           String   @id @default(cuid())
  profileId    String
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  topicId      String
  topic        Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  masteryScore Float    @default(0)
  attempts     Int      @default(0)
  correct      Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([profileId, topicId])
}

model Badge {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  description   String
  icon          String
  xpRequired    Int            @default(0)
  profileBadges ProfileBadge[]
}

model ProfileBadge {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())

  @@unique([profileId, badgeId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  completedAt DateTime?

  @@unique([profileId, lessonId])
}

model AISettings {
  id        Int      @id @default(1)
  enabled   Boolean  @default(false)
  provider  String   @default("gemini")
  baseUrl   String   @default("https://generativelanguage.googleapis.com/v1beta/openai/")
  apiKey    String?
  model     String   @default("gemini-2.0-flash")
  updatedAt DateTime @updatedAt
}
